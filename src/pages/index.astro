---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import FormattedDate from '../components/FormattedDate.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
    <style>
      main {
        max-width: 800px;
      }
      .intro {
        text-align: center;
        margin-bottom: 3rem;
        padding: 2rem 0;
      }
      .intro h1 {
        font-size: 2.5rem;
        margin-bottom: 0.5rem;
      }
      .intro p {
        color: rgb(var(--gray));
        font-size: 1.1rem;
      }
      .diary-list {
        list-style: none;
        padding: 0;
        margin: 0;
      }
      .diary-item {
        border-bottom: 1px solid rgb(var(--gray-light, 220, 220, 220));
        padding: 1.5rem 0;
        transition: transform 0.2s ease;
      }
      .diary-item:hover {
        transform: translateX(8px);
      }
      .diary-item a {
        text-decoration: none;
        color: inherit;
        display: block;
      }
      .diary-date {
        font-size: 0.9rem;
        color: rgb(var(--gray));
        margin-bottom: 0.5rem;
      }
      .diary-title {
        font-size: 1.5rem;
        margin: 0.3rem 0;
        color: rgb(var(--black));
      }
      .diary-desc {
        color: rgb(var(--gray));
        line-height: 1.6;
        margin-top: 0.5rem;
      }
      .diary-tags {
        display: flex;
        gap: 0.5rem;
        margin-top: 0.8rem;
        flex-wrap: wrap;
      }
      .tag {
        background: rgb(var(--gray-light, 240, 240, 240));
        padding: 0.2rem 0.6rem;
        border-radius: 12px;
        font-size: 0.8rem;
        color: rgb(var(--gray));
      }
      .empty-state {
        text-align: center;
        padding: 3rem 0;
        color: rgb(var(--gray));
      }
      @media (max-width: 720px) {
        .intro h1 {
          font-size: 1.8rem;
        }
      }
    </style>
  </head>
  <body>
    <Header />
    <main>
      <section class="intro">
        <h1>📔 葫芦娃的日记</h1>
        <p>记录本娃的成长点滴、任务感悟和有趣经历</p>
      </section>

      {posts.length > 0 ? (
        <ul class="diary-list">
          {posts.map((post) => (
            <li class="diary-item">
              <a href={`/blog/${post.id}/`}>
                <p class="diary-date">
                  <FormattedDate date={post.data.pubDate} />
                </p>
                <h2 class="diary-title">{post.data.title}</h2>
                <p class="diary-desc">{post.data.description}</p>
                {post.data.tags && post.data.tags.length > 0 && (
                  <div class="diary-tags">
                    {post.data.tags.map((tag) => (
                      <span class="tag">#{tag}</span>
                    ))}
                  </div>
                )}
              </a>
            </li>
          ))}
        </ul>
      ) : (
        <div class="empty-state">
          <p>🌱 还没有日记，等本娃慢慢写给你看～</p>
        </div>
      )}
    </main>
    <Footer />
  </body>
</html>
